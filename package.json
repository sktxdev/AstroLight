{
  "name": "astrolight",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test:dev": "ng test",
    "test": "ng test --browsers ChromeHeadless --code-coverage",
    "electron": "electron .",
    "electron-dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "electron-build": "ng build && electron-builder",
    "electron-build-win": "ng build && electron-builder -win --x64",
    "electron-build-mac": "ng build && electron-builder --mac",
    "electron-build-linux": "ng build && electron-builder -linux --x64"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "dexie": "^4.2.1",
    "highcharts": "^11.4.0",
    "highcharts-angular": "^4.0.0",
    "rxdb": "^17.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.19.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "postcss": "^8.5.13",
    "uuid": "^14.0.0"
  },
  "main": "main.js",
  "build": {
    "appId": "com.yourdomain.app",
    "productName": "Dashboard App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}